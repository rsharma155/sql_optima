# Database Credentials
DB_USER=dbmonitor
DB_PASSWORD=change_me_in_production_use_strong_password

# Database Name
DB_NAME=dbmonitor_metrics

# Backup Retention (days) - Backups older than this will be auto-deleted
BACKUP_RETENTION_DAYS=30

# Optional: TimescaleDB connection settings (for Go backend)
TIMESCALEDB_HOST=localhost
TIMESCALEDB_PORT=5433
TIMESCALEDB_SSLMODE=disable
# Deployment: "docker" = compose supplies Timescale (DB_*); UI goes straight to monitored-server onboarding.
# "dedicated" (default) = use /setup to save Timescale to ../data/timescale_connection.enc.json first (unless TIMESCALE_USE_ENV_ONLY=1).
# SQL_OPTIMA_DEPLOYMENT=docker
# TIMESCALE_USE_ENV_ONLY=1

# API security (see docs/threat_model.md)
# AUTH_REQUIRED=1 forces JWT on dashboard APIs; requires JWT_SECRET (32+ chars) and Timescale for optima_users (local auth).
AUTH_REQUIRED=0
AUTH_MODE=local
JWT_SECRET=replace-with-32-byte-random-secret-in-production
# OIDC_ISSUER_URL=https://keycloak.example/realms/yourrealm
# OIDC_AUDIENCE=your-client-id

# Redis + Asynq (optional). When set, API enqueues live/historical collector ticks; run cmd/worker or rely on in-process consumer.
REDIS_ADDR=

# Envelope encryption for stored credentials (optional module)
# CREDENTIAL_MASTER_KEY=base64-of-32-bytes-or-long-passphrase-hashed

# Observability
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# HEALTH_CHECK_TIMESCALE=1

# Optional: Archive settings
ARCHIVE_DATA_PATH=./data/archive
ARCHIVE_BATCH_SIZE=10000
