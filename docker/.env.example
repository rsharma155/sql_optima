# SQL Optima — Docker Compose environment variables
# Copy this file to .env and adjust values before running: docker compose up --build

# ---------- TimescaleDB (metrics store) ----------
DB_USER=dbmonitor
DB_PASSWORD=change_me_in_production_use_strong_password
DB_NAME=dbmonitor_metrics

# ---------- API server ----------
API_PORT=8080

# Auth: enabled by default to match platform compose; replace JWT_SECRET with a strong value before use.
AUTH_REQUIRED=1
JWT_SECRET=change-me-to-32chars-minimum-for-prod

# ---------- Vault (Transit KMS for credential encryption) ----------
# Dev mode defaults below — for production use external Vault + AppRole.
VAULT_TOKEN=root
VAULT_TRANSIT_KEY=sql-optima

# ---------- Monitored server credentials (optional) ----------
# If you prefer config.yaml over the web UI for adding targets, supply
# credentials via env vars using the pattern: DB_<INSTANCE_NAME>_USER / _PASSWORD
# Example:
# DB_SQL_PROD_01_USER=dbmonitor_admin
# DB_SQL_PROD_01_PASSWORD=SuperSecretPassword
# DB_PG_CLUSTER_01_USER=postgres_admin
# DB_PG_CLUSTER_01_PASSWORD=StrongPGPassword
