# Frontend Standalone (Optional if user prefers pure Nginx over Go serving)
# Build context: parent of sql_monitoring_UI (same as backend).
FROM nginx:alpine

RUN rm -rf /usr/share/nginx/html/*

COPY sql_monitoring_UI/docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY sql_monitoring_UI/frontend/ /usr/share/nginx/html/

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
